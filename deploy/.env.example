# Vault Sync server config. Copy to .env next to docker-compose.yml.
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
DATA_DIR=/data

# ---- Option A: existing S3-compatible storage (recommended if you already
#      run MinIO). Create a dedicated bucket + access key first.
S3_ENDPOINT=http://192.168.1.10:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vault-sync

# ---- Option B: bundled MinIO (docker compose --profile bundled-minio up -d)
#      Uncomment these, comment out option A's endpoint/keys, pick a strong
#      root password. S3 credentials are the MinIO root credentials here.
#S3_ENDPOINT=http://minio:9000
#MINIO_ROOT_USER=vaultsync
#MINIO_ROOT_PASSWORD=
#S3_ACCESS_KEY=vaultsync
#S3_SECRET_KEY=

# Account password hash — generate with:
#   docker run --rm ghcr.io/artislismanis/vault-sync-server:latest \
#     node dist/cli/admin.cjs hash-password '<your-password>'
ACCOUNT_PASSWORD_HASH=
