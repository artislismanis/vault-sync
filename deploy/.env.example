# Vault Sync deployment variables.
#
# docker compose CLI:  copy to .env next to docker-compose.yml.
# Portainer:           don't use a file — paste these as stack
#                      "Environment variables" (or use its "load from .env"
#                      upload) when creating the stack.
# Container Manager:   set these in the project's environment settings.
#
# NOTE for .env files: if a value ever contains `$`, wrap it in single
# quotes — docker compose interpolates unquoted values.

# ---- Option A: existing S3-compatible storage (recommended if you already
#      run MinIO). Create a dedicated bucket + access key first.
S3_ENDPOINT=http://192.168.1.10:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vault-sync

# ---- Option B: bundled MinIO (docker compose --profile bundled-minio up -d)
#      S3_ACCESS_KEY/S3_SECRET_KEY double as the MinIO root credentials —
#      pick a strong secret. The bucket is created automatically.
#S3_ENDPOINT=http://minio:9000
#S3_ACCESS_KEY=vaultsync
#S3_SECRET_KEY=
#S3_BUCKET=vault-sync

# Account password hash — generate with:
#   docker run --rm ghcr.io/artislismanis/vault-sync-server:latest \
#     node dist/cli/admin.cjs hash-password '<your-password>'
ACCOUNT_PASSWORD_HASH=

# Optional overrides
# Pin the server release (recommended) — avoids stale cached :latest images.
# The plugin (BRAT) and server versions must match on protocol-breaking
# releases; release notes call those out.
#VAULT_SYNC_VERSION=0.0.4
#PUBLISH_PORT=8080
#LOG_LEVEL=info
#S3_REGION=us-east-1
