# Server config — env vars only (12-factor). Copy to .env and fill in your
# S3-compatible endpoint (existing MinIO instance, or any S3/R2/B2).
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Local dir for the rebuildable SQLite index (NOT source of truth — the bucket is).
DATA_DIR=./data

S3_ENDPOINT=http://your-minio-host:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vault-sync

# Generate with: npm run -w server admin -- hash-password <password>
ACCOUNT_PASSWORD_HASH=
