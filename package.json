{
  "name": "vault-sync",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "shared",
    "server",
    "plugin"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit -p shared && tsc --noEmit -p server && tsc --noEmit -p plugin",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
