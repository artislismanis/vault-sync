# Force LF (Unix) line endings for files that run inside the Linux container.
# Without this, Windows git (core.autocrlf=true) converts to CRLF, which
# breaks shebangs: the kernel sees #!/bin/bash\r → "no such file or directory".

*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.mjs       text eol=lf
*.mts       text eol=lf
*.conf      text eol=lf

# Mark binary assets so git doesn't try to diff or line-end-normalise them.
*.png       binary
*.gif       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary

# Keep generated lockfiles out of GitHub language stats and PR diff noise.
package-lock.json linguist-generated=true
